# ─── Nexus Aviation Suite — Environment Variables ─────────────────────────────
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL / Supabase (relational — users, roles, alerts, audit) ────────
# Supabase setup (Settings → Database → Connection string):
#   DATABASE_URL  → "Transaction pooler"  port 6543  ?pgbouncer=true  (app queries)
#   DIRECT_URL    → "Session pooler"      port 5432  no pgbouncer flag (prisma db push / migrate)
#   Both use the pooler host (aws-0-*.pooler.supabase.com), NOT the direct DB host (db.*.supabase.co)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── TimescaleDB (time-series — sensor readings, flow metrics) ────────────────
TIMESCALE_USER=nexus_ts
TIMESCALE_PASSWORD=timescale_secret
TIMESCALE_DB=nexus_timeseries
TIMESCALE_URL=postgresql://nexus_ts:timescale_secret@localhost:5433/nexus_timeseries

# ─── Neo4j (airport topology graph) ──────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexus_graph

# ─── Redis (hot cache — live metrics, alert states, forecasts) ────────────────
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PASSWORD=redis_secret

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
KAFKA_GROUP_ID_INGESTOR=nexus-ingestor-group
KAFKA_GROUP_ID_ANALYTICS=nexus-analytics-group
KAFKA_GROUP_ID_NOTIFICATION=nexus-notification-group

# ─── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=8h

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=MY_GEMINI_API_KEY
APP_URL=MY_APP_URL
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_KEY=your_azure_openai_key

# ─── Python FastAPI Analytics Bridge ─────────────────────────────────────────
PROPHET_URL=http://localhost:8000

# ─── Ingestor Service ─────────────────────────────────────────────────────────
# Set to 'mock' for POC; 'live' for real sensor integration
CONNECTOR_MODE=mock

# ─── Notification Channels (optional / feature-flagged) ──────────────────────
# SENDGRID_API_KEY=your_sendgrid_key
# SENDGRID_FROM_EMAIL=alerts@nexus.airport.internal
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_FROM_NUMBER=+1234567890

# ─── Service Ports (for local development without Docker) ─────────────────────
API_GATEWAY_PORT=4000
INGESTOR_PORT=4001
ANALYTICS_PORT=4002
NOTIFICATION_PORT=4003
